---
config:
  theme: base
  themeVariables:
    primaryColor: "#ede9fe"
    primaryTextColor: "#1c1917"
    primaryBorderColor: "#7c3aed"
    lineColor: "#78716c"
    secondaryColor: "#fef9c3"
    tertiaryColor: "#e7e5e4"
    fontFamily: "system-ui, -apple-system, sans-serif"
---
flowchart TB
    classDef state fill:#fef3c7,stroke:#f59e0b,color:#7c2d12
    classDef approved fill:#d1fae5,stroke:#10b981,color:#064e3b
    classDef notify fill:#dbeafe,stroke:#3b82f6,color:#1e3a8a
    classDef brandhub fill:#ede9fe,stroke:#7c3aed,color:#5b21b6
    classDef brieftool fill:#fef9c3,stroke:#ca8a04,color:#713f12
    classDef external fill:#e7e5e4,stroke:#78716c,color:#1c1917

    Lead([🌟 New client lead])

    subgraph Onboard[" 1 · ONBOARDING "]
        Source{How did they<br/>come in?}
        Public[Public intake form<br/>at /intake]
        Manual[AM clicks 'New brand'<br/>in dashboard]
    end

    Lead --> Source
    Source -->|Self-serve URL| Public
    Source -->|Direct contact| Manual

    subgraph Hub[" 2 · BRAND HUB · capture + approve "]
        Submitted[(submitted)]
        Draft[(draft)]
        ChatNote[🔔 Google Chat<br/>New brand intake<br/>with Review button]
        Polish[AM polishes record:<br/>· AM assigned<br/>· logos uploaded<br/>· primary color set<br/>· overview written<br/>· voice + audience]
        Gate{Pre-approve<br/>checklist passes?}
        Approve[[Approve & Sync]]
        PDF[📄 Editorial PDF<br/>generated + saved]
        DB[📁 Dropbox folder tree:<br/>/NN x SG/Brand/<br/>2026 · Assets/Logo<br/>Assets/Video Assets]
        MI[📋 Monday Intake<br/>board row updated]
        MA[🎯 Monday All Projects<br/>parent in Project Intake<br/>group · @Rendi tagged]
        SHARE[🌐 Public share page<br/>at /share/&lt;token&gt;]
        Approved[(approved)]
    end

    Public --> Submitted
    Manual --> Draft
    Submitted --> ChatNote
    ChatNote --> Polish
    Draft --> Polish
    Polish --> Gate
    Gate -->|missing items| Polish
    Gate -->|all required ✓| Approve
    Approve --> PDF
    Approve --> DB
    Approve --> MI
    Approve --> MA
    Approve --> SHARE
    PDF --> Approved
    DB --> Approved
    MI --> Approved
    MA --> Approved
    SHARE --> Approved

    subgraph Brief[" 3 · BRIEF TOOL · per-project briefs "]
        NewProject{Client orders<br/>a project?}
        OpenBrief[Open Brief Tool<br/>New brief<br/>pick client from list]
        Pull[⬅️ Pull brand data:<br/>colors · fonts · voice<br/>audience · AM contact<br/>via brand_directory view]
        Write[AM writes brief specifics:<br/>· deliverables<br/>· deadlines<br/>· copy direction<br/>· references]
        BriefShare[Brief share URL<br/>sent to creative team]
        Work[🎬 Editor / designer<br/>delivers work]
        Files[Files land in<br/>Dropbox Video Assets/<br/>or Deliverables/]
    end

    Approved --> NewProject
    NewProject -->|new project| OpenBrief
    OpenBrief --> Pull
    Pull --> Write
    Write --> BriefShare
    BriefShare --> Work
    Work --> Files

    NewProject -.->|future projects<br/>reuse same brand| OpenBrief

    class Submitted,Draft state
    class Approved approved
    class ChatNote notify
    class Polish,Approve,PDF,SHARE brandhub
    class OpenBrief,Pull,Write,BriefShare brieftool
    class Public,Manual,DB,MI,MA,Work,Files external
